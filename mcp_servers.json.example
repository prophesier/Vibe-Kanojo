{
    "mcp_servers": {
      "time": {
        "command": "uvx",
        "args": ["mcp-server-time", "--local-timezone=Asia/Shanghai"]
      },
      "ddg-search": {
        "command": "uvx",
        "args": ["duckduckgo-mcp-server"]
      },
      "uber-eats": {
        "command": "python",
        "args": ["experiments/uber_eats/server.py"]
      }
    }
}
